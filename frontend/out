# ---- build stage ----
FROM node:20-alpine AS build
WORKDIR /app

COPY package*.json ./
RUN npm ci

COPY . .
RUN npm run build

# ---- runtime stage ----
FROM nginx:1.27-alpine
COPY nginx.conf /etc/nginx/conf.d/default.conf

# SvelteKit adapter-static outputs to /build by default
COPY --from=build /app/build /usr/share/nginx/html

EXPOSE 80